<div class="px-6 py-8 max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-2 flex-wrap gap-4">
        <h2 class="text-3xl font-black uppercase tracking-tight border-b-4 border-black pb-1">Mi Dashboard</h2>
        <div class="flex items-center gap-3 flex-wrap">
            <p class="text-xs font-bold uppercase tracking-widest text-gray-500">Arrastra desde el asa derecha para
                mover tarjetas</p>
            <button id="export-btn" class="btn-secondary">↓ Exportar</button>
            <button popovertarget="popover-importar" class="btn-primary">↑ Importar</button>
            <button popovertarget="popover-nuevo-tablero" class="btn-primary">+ Tablero</button>
        </div>
    </div>
    <hr class="border-t-4 border-black mb-8">
</div>

{{> popover-importar}}
{{> popover-nuevo-tablero}}

{{#each boards}}
<div class="board-section px-6 pb-10 max-w-7xl mx-auto" data-board-id="{{this.id}}">

    <div class="flex items-center gap-3 mb-5">
        <h3 class="text-xl font-black uppercase tracking-tight border-l-[6px] border-black pl-3 flex-1">{{this.name}}
        </h3>
        <button class="board-fold-btn" data-board-id="{{this.id}}" title="Plegar tablero">‹‹</button>
        <button class="board-delete-btn" data-board-id="{{this.id}}" title="Eliminar tablero">× Eliminar</button>
    </div>

    <div class="kanban-board">
        <div class="kanban-lists" data-board-id="{{this.id}}">

            {{#each this.lists}}
            <div class="kanban-list" data-list-id="{{this.id}}" data-board-id="{{../id}}">

                <div class="kanban-list-header">
                    <span class="flex-1 overflow-hidden"
                        style="text-overflow:ellipsis;white-space:nowrap;">{{this.name}}</span>
                    <div class="flex gap-1 items-center flex-shrink-0 ml-2">
                        <span class="kanban-list-count">{{length this.cards}}</span>
                        <button class="list-fold-btn" title="Plegar">‹‹</button>
                        <button class="list-delete-btn" data-lista-id="{{this.id}}" data-tablero-id="{{../id}}"
                            title="Eliminar lista">×</button>
                    </div>
                </div>

                <div class="kanban-list-folded-panel">
                    <button class="list-unfold-btn" title="Desplegar">VER</button>
                    <span class="kanban-list-count-v">{{length this.cards}}</span>
                    <span class="kanban-list-folded-title">{{this.name}}</span>
                </div>

                <div class="kanban-cards" data-list-id="{{this.id}}" data-board-id="{{../id}}">

                    {{#each this.cards}}
                    <div class="kanban-card" data-card-id="{{this.id}}" data-list-id="{{../id}}"
                        data-board-id="{{../../id}}">

                        <div class="kanban-card-body">
                            <div class="flex items-start justify-between gap-2 mb-2">
                                <div class="kanban-card-title">{{this.titulo}}</div>
                                <button draggable="false" data-edit-btn popovertarget="edit-{{this.id}}"
                                    title="Editar tarjeta" class="kanban-card-edit-btn">✎</button>
                            </div>

                            <div class="flex gap-1 flex-wrap mb-2">
                                <span class="badge badge-{{this.prioridad}}">{{this.prioridad}}</span>
                                <span class="tag tag-{{this.tag}}">{{this.tag}}</span>
                            </div>

                            {{#if this.descripcion}}
                            <div class="kanban-card-desc">{{this.descripcion}}</div>
                            {{/if}}

                            <div class="kanban-card-meta">
                                <span>{{this.responsable}}</span>
                                {{#if this.fecha_fin}}
                                <span>{{formatDate this.fecha_fin}}</span>
                                {{/if}}
                            </div>
                        </div>

                        <div class="kanban-drag-handle" title="Arrastrar tarjeta">
                            <div class="drag-dots"></div>
                        </div>

                        {{> popover-editar-tarjeta listId=../id}}

                    </div>
                    {{/each}}
                </div>

                <div class="p-3 pt-1">
                    <button popovertarget="popover-{{../id}}-{{this.id}}"
                        class="w-full border-3 border-black bg-black text-white font-black uppercase tracking-widest text-xs py-2 px-4 hover:bg-white hover:text-black transition-all duration-100 cursor-pointer shadow-brutal-sm hover:shadow-brutal">
                        + Agregar Tarjeta
                    </button>
                </div>

                {{> popover-agregar-tarjeta boardId=../id}}

            </div>
            {{/each}}

            <button popovertarget="popover-nueva-lista-{{this.id}}" class="kanban-list-new">
                <span class="nueva-lista-icon">+</span>
                <span class="nueva-lista-label">Nueva Lista</span>
            </button>

        </div>
    </div>
</div>

{{> popover-nueva-lista}}
{{/each}}

<script src="/dashboard.js"></script>
