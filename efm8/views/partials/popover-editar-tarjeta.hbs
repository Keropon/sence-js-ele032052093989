<div id="edit-{{id}}" popover="manual">
    <h4 class="text-lg font-black uppercase tracking-tight mb-1 border-b-4 border-black pb-2">Editar Tarjeta</h4>

    <form method="PUT" action="/api/listas/{{listId}}/tarjetas/{{id}}" data-ajax-form>
        <div class="grid grid-cols-2 gap-3 mb-4">
            <div class="col-span-2">
                <label class="form-label">Título</label>
                <input type="text" name="titulo" value="{{titulo}}" required class="form-input">
            </div>
            <div>
                <label class="form-label">Prioridad</label>
                <select name="prioridad" class="select-brutal">
                    <option value="Feature" {{#if (eq prioridad "Feature")}}selected{{/if}}>Feature</option>
                    <option value="Task" {{#if (eq prioridad "Task")}}selected{{/if}}>Task</option>
                    <option value="Bug" {{#if (eq prioridad "Bug")}}selected{{/if}}>Bug</option>
                    <option value="Improvement" {{#if (eq prioridad "Improvement")}}selected{{/if}}>Improvement</option>
                </select>
            </div>
            <div>
                <label class="form-label">TAG</label>
                <select name="tag" class="select-brutal">
                    <option value="Feature" {{#if (eq tag "Feature")}}selected{{/if}}>Feature</option>
                    <option value="Bug" {{#if (eq tag "Bug")}}selected{{/if}}>Bug</option>
                    <option value="Hotfix" {{#if (eq tag "Hotfix")}}selected{{/if}}>Hotfix</option>
                </select>
            </div>
            <div class="col-span-2">
                <label class="form-label">Descripción</label>
                <textarea name="descripcion" rows="2" class="form-input resize-none">{{descripcion}}</textarea>
            </div>
            <div>
                <label class="form-label">Fecha Inicio</label>
                <input type="date" name="fecha_inicio" value="{{fecha_inicio}}" class="form-input">
            </div>
            <div>
                <label class="form-label">Fecha Fin</label>
                <input type="date" name="fecha_fin" value="{{fecha_fin}}" class="form-input">
            </div>
            <div>
                <label class="form-label">Autor</label>
                <input type="text" name="autor" value="{{autor}}" class="form-input">
            </div>
            <div>
                <label class="form-label">Responsable</label>
                <input type="text" name="responsable" value="{{responsable}}" class="form-input">
            </div>
        </div>

        <div class="flex gap-2 mb-3">
            <button type="submit" class="btn-primary flex-1">Guardar</button>
            <button type="button" popovertarget="edit-{{id}}" popovertargetaction="hide"
                class="btn-secondary flex-1">Cancelar</button>
        </div>
    </form>

    <form method="DELETE" action="/api/listas/{{listId}}/tarjetas/{{id}}" data-ajax-form
        onsubmit="return confirm('¿Eliminar esta tarjeta? Esta acción no se puede deshacer.')">
        <button type="submit" class="btn-danger w-full">Eliminar Tarjeta</button>
    </form>
</div>
