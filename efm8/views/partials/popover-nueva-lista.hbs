<div id="popover-nueva-lista-{{id}}" popover="manual">
    <h4 class="text-lg font-black uppercase tracking-tight mb-1 border-b-4 border-black pb-2">Nueva Lista</h4>
    <p class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-4">Tablero: {{name}}</p>

    <form method="POST" action="/api/tableros/{{id}}/listas" data-ajax-form>
        <div class="mb-4">
            <label class="form-label">Nombre de la lista</label>
            <input type="text" name="nombre" placeholder="Ej: En revisión" required class="form-input">
        </div>
        <div class="flex gap-2">
            <button type="submit" class="btn-primary flex-1">Crear Lista</button>
            <button type="button" popovertarget="popover-nueva-lista-{{id}}" popovertargetaction="hide"
                class="btn-secondary flex-1">Cancelar</button>
        </div>
    </form>
</div>
