<div class="max-w-xl mx-auto my-20 px-4 text-center">
    <div class="border-3 border-black shadow-brutal p-10">
        <h1 class="text-8xl font-black tracking-tighter mb-4">{{code}}</h1>
        <hr class="border-t-4 border-black mb-6">
        <h2 class="text-2xl font-black uppercase tracking-tight mb-3">{{message}}</h2>
        <p class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-10">
            {{#if detail}}{{detail}}{{else}}La ruta que buscas no existe o fue movida.{{/if}}
        </p>
        <a href="/" class="btn-primary inline-block">← Volver al inicio</a>
    </div>
</div>
