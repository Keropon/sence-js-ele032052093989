<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KanbanPro</title>
    <link rel="shortcut icon" href="/favicon.png" type="image/png">
    <link rel="stylesheet" href="/style.css">
</head>

<body class="bg-white text-black font-sans min-h-screen flex flex-col">

    <header class="bg-black text-white px-6 py-4 border-b-4 border-black" style="view-transition-name: site-header;">
        <div class="flex items-center justify-between max-w-7xl mx-auto flex-wrap gap-x-4">

            <a href="/" class="text-white font-black text-2xl uppercase tracking-tight no-underline hover:no-underline"
                style="background:none;padding:0;">KanbanPro</a>

            <button id="nav-toggle"
                class="md:hidden text-white border-2 border-white font-black text-xl px-2 leading-none hover:bg-white hover:text-black transition-all duration-100"
                aria-label="Menú" aria-expanded="false">☰</button>

            <nav id="main-nav"
                class="hidden md:flex w-full md:w-auto order-last md:order-none flex-col md:flex-row gap-1 items-stretch md:items-center pt-3 md:pt-0 border-t-2 md:border-0 border-white/20 mt-1 md:mt-0">

                <a href="/"
                    class="text-white font-bold uppercase text-xs tracking-widest px-3 py-2 border-2 border-transparent hover:border-white hover:bg-white hover:text-black transition-all duration-100">Inicio</a>
                <a href="/dashboard"
                    class="text-white font-bold uppercase text-xs tracking-widest px-3 py-2 border-2 border-transparent hover:border-white hover:bg-white hover:text-black transition-all duration-100">Dashboard</a>

                {{#if user}}
                <span
                    class="text-white font-bold uppercase text-xs tracking-widest px-3 py-2 opacity-60 truncate max-w-[200px]">{{user.email}}</span>
                <a href="/logout"
                    class="text-white font-bold uppercase text-xs tracking-widest px-3 py-2 border-2 border-white hover:bg-white hover:text-black transition-all duration-100">Cerrar
                    Sesión</a>
                {{else}}
                <a href="/login"
                    class="text-white font-bold uppercase text-xs tracking-widest px-3 py-2 border-2 border-transparent hover:border-white hover:bg-white hover:text-black transition-all duration-100">Login</a>
                <a href="/register"
                    class="text-white font-bold uppercase text-xs tracking-widest px-3 py-2 border-2 border-transparent hover:border-white hover:bg-white hover:text-black transition-all duration-100">Registro</a>
                {{/if}}

            </nav>
        </div>
    </header>

    <main class="flex-1" style="view-transition-name: main-content;">
        {{{body}}}
    </main>

    <footer class="bg-black text-white px-6 py-6 border-t-4 border-black mt-auto">
        <div class="max-w-7xl mx-auto flex items-center justify-between flex-wrap gap-2">
            <p class="font-black uppercase tracking-widest text-xs m-0">&copy; 2025 KanbanPro</p>
            <p class="font-bold uppercase tracking-widest text-xs m-0">Express + Handlebars + Tailwind</p>
        </div>
    </footer>

    <script src="/gsap/dist/gsap.min.js"></script>
    <script src="/gsap/dist/Draggable.min.js"></script>
    <script src="/main.js"></script>
</body>

</html>